{
    "head-effect": {
        "type": "header",
        "description": "Effect for inactive windows"
    },
    "mode": {
        "type": "combobox",
        "default": "both",
        "description": "What happens to inactive windows",
        "options": {
            "Dim and desaturate": "both",
            "Dim only": "dim",
            "Desaturate only": "desaturate"
        }
    },
    "dim-amount": {
        "type": "scale",
        "default": 0.25,
        "min": 0.0,
        "max": 0.8,
        "step": 0.05,
        "description": "Dim strength (0 = none, 0.8 = very dark)"
    },
    "desaturate-amount": {
        "type": "scale",
        "default": 0.5,
        "min": 0.0,
        "max": 1.0,
        "step": 0.05,
        "description": "Desaturation strength (0 = full color, 1 = grayscale)"
    },
    "animation-time": {
        "type": "scale",
        "default": 150,
        "min": 0,
        "max": 400,
        "step": 25,
        "units": "ms",
        "description": "Fade duration on focus change (0 = instant)"
    },
    "head-behavior": {
        "type": "header",
        "description": "Behavior"
    },
    "respect-transient": {
        "type": "checkbox",
        "default": false,
        "description": "Keep a window bright while a MODAL dialog of it holds focus. Off = strict per-window (recommended; treats e.g. a PhpStorm floating window as its own window)"
    },
    "dim-when-no-focus": {
        "type": "checkbox",
        "default": false,
        "description": "Also dim every window when nothing is focused (e.g. after clicking the desktop)"
    }
}
